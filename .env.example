# syslog-mcp environment variables
# Copy to .env and adjust for your environment.
#
# SYSLOG_*     = syslog listener settings
# SYSLOG_MCP_* = MCP server + storage settings

# --- Syslog listener ---

# Host to bind UDP + TCP listeners (no port here)
SYSLOG_HOST=0.0.0.0

# Port for syslog (UDP + TCP share the same port)
SYSLOG_PORT=1514

# Max syslog message size in bytes
# SYSLOG_MAX_MESSAGE_SIZE=8192

# Batch writer: entries per flush
# SYSLOG_BATCH_SIZE=100

# Batch writer: flush interval in milliseconds
# SYSLOG_FLUSH_INTERVAL=500

# --- MCP server ---

# Host to bind MCP HTTP server (no port here)
SYSLOG_MCP_HOST=0.0.0.0

# Port for MCP HTTP server
SYSLOG_MCP_PORT=3100

# Optional bearer token for MCP endpoint authentication.
# When set, all requests to /mcp and /sse must include:
#   Authorization: Bearer <token>
# Leave unset to disable — suitable when SWAG handles auth upstream.
# SYSLOG_MCP_API_TOKEN=your-secret-token-here

# --- Storage ---

# SQLite database path (inside container: /data/syslog.db)
SYSLOG_MCP_DB_PATH=/data/syslog.db

# Connection pool size
SYSLOG_MCP_POOL_SIZE=4

# Log retention in days (0 = keep forever)
SYSLOG_MCP_RETENTION_DAYS=90

# --- Docker Compose ---

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info

# Docker network name (must exist; use `docker network create <name>`)
DOCKER_NETWORK=syslog_mcp

# Data volume: named volume (default) or bind mount path (e.g. ./data)
# SYSLOG_MCP_DATA_VOLUME=syslog-mcp-data

# Container runtime user/group for bind-mounted data directories.
# Override these if your host user does not use 1000:1000.
SYSLOG_UID=1000
SYSLOG_GID=1000
