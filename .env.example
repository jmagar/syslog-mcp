# syslog-mcp environment variables
# Copy to .env and adjust for your environment.
# Prefix is SYSLOG_MCP_ (single underscore), __ separates section from key.

# Syslog listener bind addresses
SYSLOG_MCP_SYSLOG__UDP_BIND=0.0.0.0:1514
SYSLOG_MCP_SYSLOG__TCP_BIND=0.0.0.0:1514

# SQLite database path (inside container)
SYSLOG_MCP_STORAGE__DB_PATH=/data/syslog.db

# Connection pool size
SYSLOG_MCP_STORAGE__POOL_SIZE=4

# Log retention in days (0 = keep forever)
SYSLOG_MCP_STORAGE__RETENTION_DAYS=90

# MCP HTTP server bind address
SYSLOG_MCP_MCP__BIND=0.0.0.0:3100

# Optional bearer token for MCP endpoint authentication.
# When set, all requests to /mcp and /sse must include:
#   Authorization: Bearer <token>
# Leave unset (default) to disable — suitable when SWAG handles auth upstream.
# SYSLOG_MCP_MCP__API_TOKEN=your-secret-token-here

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info

# Docker network name for reverse proxy attachment (default: jakenet)
DOCKER_NETWORK=syslog_mcp
