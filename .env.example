# syslog-mcp environment variables
# Copy to .env and adjust for your environment.
# All vars use SYSLOG_MCP__ prefix with __ for nesting.

# Syslog listener bind addresses
SYSLOG_MCP__SYSLOG__UDP_BIND=0.0.0.0:1514
SYSLOG_MCP__SYSLOG__TCP_BIND=0.0.0.0:1514

# SQLite database path (inside container)
SYSLOG_MCP__STORAGE__DB_PATH=/data/syslog.db

# Connection pool size
SYSLOG_MCP__STORAGE__POOL_SIZE=4

# Log retention in days (0 = keep forever)
SYSLOG_MCP__STORAGE__RETENTION_DAYS=90

# MCP HTTP server bind address
SYSLOG_MCP__MCP__BIND=0.0.0.0:3100

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info
