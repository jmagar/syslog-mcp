{
  "description": "Sync userConfig credentials to .env and enforce permissions",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sync-env.sh"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/fix-env-perms.sh"
      }
    ]
  }
}
